/// Splice-time-sealed config substrate for builtin middlewares.
///
/// A builtin that needs operator-supplied configuration imports
/// `splicer:builtin-config/get`. Splicer codegens a tiny provider
/// component (from a single shared template parameterized by a
/// per-inject-site key-value table) and wires it to the builtin's
/// import at WAC-compose time.
///
/// Values are string-typed at the WIT boundary. Each builtin
/// parses the strings it cares about into typed config at init
/// time. See `docs/TODO/builtin-config-substrate.md` for the full
/// rationale (notably why we don't use typed records).
package splicer:builtin-config@0.1.0;

interface get {
    /// Look up a config value by key. Returns `none` if the key was
    /// not set in the splice-config; the caller falls back to its
    /// own default.
    get: func(key: string) -> option<string>;
}

world provider {
    export get;
}
